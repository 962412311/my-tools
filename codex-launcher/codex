check_subscription() {
  python3 - <<'PY'
import base64
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

auth_path = Path.home() / '.codex' / 'auth.json'
accounts_url = 'https://chatgpt.com/backend-api/accounts/check/v4-2023-04-27'
oauth_url = 'https://auth.openai.com/oauth/token'

def env_int(name, default):
    try:
        value = int(os.environ.get(name, default))
    except (TypeError, ValueError):
        return default
    return value if value > 0 else default

startup_http_attempts = env_int('CODEX_STARTUP_HTTP_ATTEMPTS', 3)
token_refresh_min_seconds = env_int('CODEX_TOKEN_REFRESH_MIN_SECONDS', 86400)

def warn(message):
    print(f'[WARN] {message}')

def info(message):
    print(f'[INFO] {message}')

def urlopen_json(request, timeout=20, attempts=startup_http_attempts):
    last_exc = None
    for _ in range(attempts):
        try:
            with urllib.request.urlopen(request, timeout=timeout) as response:
                return json.loads(response.read().decode())
        except urllib.error.HTTPError:
            raise
        except Exception as exc:
            last_exc = exc
    raise last_exc

def decode_jwt(token):
    parts = token.split('.')
    if len(parts) < 2:
        return {}
    payload = parts[1] + '=' * (-len(parts[1]) % 4)
    return json.loads(base64.urlsafe_b64decode(payload.encode('ascii')))

def token_payload(tokens, token_name):
    token = tokens.get(token_name)
    if not isinstance(token, str) or not token.strip():
        return {}
    try:
        return decode_jwt(token)
    except Exception:
        return {}

def extract_client_id(tokens):
    for token_name in ('id_token', 'access_token'):
        payload = token_payload(tokens, token_name)
        aud = payload.get('aud')
        if isinstance(aud, list) and aud:
            return str(aud[0])
        if isinstance(aud, str) and aud:
            return aud
    return None

def token_seconds_until_expiry(tokens, token_name):
    payload = token_payload(tokens, token_name)
    exp = payload.get('exp')
    if not isinstance(exp, (int, float)):
        return None
    return exp - datetime.now(timezone.utc).timestamp()

def should_refresh_tokens(tokens):
    access_token = tokens.get('access_token')
    if not isinstance(access_token, str) or not access_token.strip():
        return True
    seconds_left = token_seconds_until_expiry(tokens, 'access_token')
    if seconds_left is None:
        return True
    return seconds_left <= token_refresh_min_seconds

def save_auth(auth):
    tmp_path = auth_path.with_suffix('.json.tmp')
    tmp_path.write_text(json.dumps(auth, ensure_ascii=False, indent=2) + '\n')
    try:
        tmp_path.chmod(auth_path.stat().st_mode & 0o777)
    except Exception:
        pass
    tmp_path.replace(auth_path)

def refresh_tokens(auth, tokens):
    refresh_token = tokens.get('refresh_token')
    client_id = extract_client_id(tokens)
    if not isinstance(refresh_token, str) or not refresh_token.strip() or not client_id:
        return tokens

    body = urllib.parse.urlencode({
        'grant_type': 'refresh_token',
        'refresh_token': refresh_token,
        'client_id': client_id,
    }).encode()
    request = urllib.request.Request(
        oauth_url,
        data=body,
        headers={'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded'},
        method='POST',
    )
    try:
        refreshed = urlopen_json(request)
    except Exception as exc:
        warn(f'刷新 Codex 登录 token 失败，将使用本地缓存：{exc}')
        return tokens

    updated = dict(tokens)
    for key in ('id_token', 'access_token', 'refresh_token'):
        value = refreshed.get(key)
        if isinstance(value, str) and value.strip():
            updated[key] = value
    auth['tokens'] = updated
    auth['last_refresh'] = datetime.now(timezone.utc).isoformat()
    try:
        save_auth(auth)
    except Exception as exc:
        warn(f'保存刷新后的 Codex 登录信息失败，将继续检查：{exc}')
    return updated

def nested_auth(payload):
    nested = payload.get('https://api.openai.com/auth')
    return nested if isinstance(nested, dict) else {}

def extract_account_id(tokens):
    account_id = tokens.get('account_id')
    if isinstance(account_id, str) and account_id.strip():
        return account_id.strip()
    for token_name in ('id_token', 'access_token'):
        account_id = nested_auth(token_payload(tokens, token_name)).get('chatgpt_account_id')
        if isinstance(account_id, str) and account_id.strip():
            return account_id.strip()
    return None

def subscription_from_accounts(tokens):
    access_token = tokens.get('access_token')
    if not isinstance(access_token, str) or not access_token.strip():
        return None

    account_id = extract_account_id(tokens)
    headers = {
        'Accept': 'application/json',
        'Authorization': f'Bearer {access_token}',
        'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36',
    }
    if account_id:
        headers['ChatGPT-Account-ID'] = account_id
        headers['OpenAI-Account-ID'] = account_id

    request = urllib.request.Request(accounts_url, headers=headers)
    try:
        payload = urlopen_json(request)
    except urllib.error.HTTPError as exc:
        warn(f'查询 Codex 账号订阅失败，将使用本地 token：{exc}')
        return None
    except Exception as exc:
        warn(f'查询 Codex 账号订阅失败，将使用本地 token：{exc}')
        return None

    accounts = payload.get('accounts')
    if not isinstance(accounts, dict):
        return None

    account = None
    if account_id and isinstance(accounts.get(account_id), dict):
        account = accounts[account_id]
    elif isinstance(accounts.get('default'), dict):
        account = accounts['default']
    else:
        for candidate in accounts.values():
            entitlement = candidate.get('entitlement') if isinstance(candidate, dict) else None
            if isinstance(entitlement, dict) and entitlement.get('has_active_subscription') is True:
                account = candidate
                break

    entitlement = account.get('entitlement') if isinstance(account, dict) else None
    if not isinstance(entitlement, dict):
        return None

    for key in ('renews_at', 'expires_at', 'cancels_at'):
        value = entitlement.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()
    return None

def subscription_from_tokens(tokens):
    for token_name in ('id_token', 'access_token'):
        subscription_until = nested_auth(token_payload(tokens, token_name)).get(
            'chatgpt_subscription_active_until'
        )
        if isinstance(subscription_until, str) and subscription_until.strip():
            return subscription_until.strip()
    return None

def subscription_metadata_from_tokens(tokens):
    for token_name in ('id_token', 'access_token'):
        auth = nested_auth(token_payload(tokens, token_name))
        subscription_until = auth.get('chatgpt_subscription_active_until')
        subscription_start = auth.get('chatgpt_subscription_active_start')
        if isinstance(subscription_until, str) and subscription_until.strip():
            return {
                'start': subscription_start.strip() if isinstance(subscription_start, str) else '',
                'until': subscription_until.strip(),
            }
    return {}

def add_months(value, months):
    month = value.month - 1 + months
    year = value.year + month // 12
    month = month % 12 + 1
    days_in_month = (
        31,
        29 if year % 4 == 0 and (year % 100 != 0 or year % 400 == 0) else 28,
        31, 30, 31, 30, 31, 31, 30, 31, 30, 31,
    )
    day = min(value.day, days_in_month[month - 1])
    return value.replace(year=year, month=month, day=day)

def parse_time(value):
    if not isinstance(value, str) or not value.strip():
        return None
    try:
        parsed = datetime.fromisoformat(value.strip().replace('Z', '+00:00'))
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=timezone.utc)
    return parsed

def current_subscription_until_from_tokens(tokens):
    metadata = subscription_metadata_from_tokens(tokens)
    subscription_until = metadata.get('until')
    expiry = parse_time(subscription_until)
    if not expiry:
        return subscription_until

    now = datetime.now(timezone.utc)
    if expiry > now:
        return subscription_until

    start = parse_time(metadata.get('start'))
    if not start or start >= expiry:
        return subscription_until

    months = (expiry.year - start.year) * 12 + expiry.month - start.month
    if months <= 0:
        return subscription_until

    projected = expiry
    while projected <= now:
        projected = add_months(projected, months)
    return projected.isoformat()

if not auth_path.exists():
    warn('未找到 Codex 登录信息，跳过订阅检查。')
    sys.exit(0)

try:
    auth_text = auth_path.read_text().strip()
    if not auth_text:
        raise ValueError('auth.json is empty')
    auth = json.loads(auth_text)
except Exception as exc:
    warn(f'无法读取 Codex 登录信息：{exc}')
    sys.exit(0)

if auth.get('auth_mode') != 'chatgpt':
    info('当前不是 ChatGPT 登录，跳过订阅检查。')
    sys.exit(0)

tokens = auth.get('tokens') or {}
if should_refresh_tokens(tokens):
    tokens = refresh_tokens(auth, tokens)
subscription_until = subscription_from_accounts(tokens) or current_subscription_until_from_tokens(tokens)

if not subscription_until:
    warn('未找到订阅到期时间，跳过检查。')
    sys.exit(0)

normalized_until = subscription_until.replace('Z', '+00:00')
try:
    expiry = datetime.fromisoformat(normalized_until)
except ValueError:
    warn(f'无法解析订阅到期时间：{subscription_until}')
    sys.exit(0)

now = datetime.now(timezone.utc)
remaining = expiry - now
remaining_days = remaining.total_seconds() / 86400
expiry_text = expiry.astimezone(timezone.utc).strftime('%Y-%m-%d %H:%M:%S')

if remaining.total_seconds() <= 0:
    warn(f'Codex 订阅已过期，到期时间：{expiry_text}。')
    sys.exit(0)

if remaining_days <= 7:
    warn(f'Codex 订阅还剩 {remaining_days:.1f} 天，到期时间：{expiry_text}。')
    sys.exit(0)

info(f'Codex 订阅还剩 {remaining_days:.1f} 天，到期时间：{expiry_text}。')
PY
}

touch_update_stamp() {
