should_apply_codex_defaults() {
  local first="${1:-}"
  case "$first" in
    login|logout|mcp|plugin|mcp-server|app-server|remote-control|completion|update|doctor|sandbox|debug|apply|a|archive|delete|unarchive|cloud|exec-server|features|help)
      return 1
      ;;
    -h|--help|-V|--version)
      return 1
      ;;
  esac
  return 0
}

run_real_codex() {
  local has_model=0
  local has_reasoning_effort=0
  local arg prev=""
  local defaults=()

  if should_apply_codex_defaults "$@"; then
    for arg in "$@"; do
      if [ "$prev" = "-m" ] || [ "$prev" = "--model" ]; then
        has_model=1
      elif [ "$prev" = "-c" ] || [ "$prev" = "--config" ]; then
        case "$arg" in
          model=*|model_reasoning_effort=*)
            [ "${arg%%=*}" = "model" ] && has_model=1
            [ "${arg%%=*}" = "model_reasoning_effort" ] && has_reasoning_effort=1
            ;;
        esac
      fi

      case "$arg" in
        -m|--model|-c|--config)
          prev="$arg"
          continue
          ;;
        --model=*|model=*)
          has_model=1
          ;;
        --config=model=*|--config=model_reasoning_effort=*)
          case "${arg#--config=}" in
            model=*) has_model=1 ;;
            model_reasoning_effort=*) has_reasoning_effort=1 ;;
          esac
          ;;
        model_reasoning_effort=*)
          has_reasoning_effort=1
          ;;
      esac
      prev=""
    done

    if [ "$has_model" -eq 0 ]; then
      defaults+=("-m" "$default_codex_model")
    fi
    if [ "$has_reasoning_effort" -eq 0 ]; then
      defaults+=("-c" "model_reasoning_effort=\"$default_codex_reasoning_effort\"")
    fi
  fi

  if [ "${#defaults[@]}" -gt 0 ]; then
    "$real_codex" "${defaults[@]}" "$@"
  else
    "$real_codex" "$@"
  fi
}

run_codex() {
  local status
  start_blackhole_beacon "$@" || true
  if [ -n "${blackhole_beacon_pid:-}" ]; then
    set +e
    run_real_codex "$@"
    status=$?
    kill "$blackhole_beacon_pid" >/dev/null 2>&1 || true
    wait "$blackhole_beacon_pid" >/dev/null 2>&1 || true
    exit "$status"
  fi

  run_real_codex "$@"
}

